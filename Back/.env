# =========================================================================
# CONFIGURACIÓN DEL SERVIDOR Y BASE DE DATOS
# =========================================================================

# Puerto en el que correrá tu servidor Backend
PORT=5000

# -------------------------------------------------------------------------
# CAMBIO DE SERVIDOR / BASE DE DATOS:
# Si decides usar otro servidor de PostgreSQL (local o remoto), 
# solo debes modificar los valores de aquí abajo.
# -------------------------------------------------------------------------

# Nombre de usuario de tu base de datos (Ej: postgres)
DB_USER=postgres

# Contraseña de tu usuario de base de datos
DB_PASSWORD=123456

# Dirección del servidor. 
# Si el Back no encuentra a Postgres, prueba cambiar 'localhost' por '127.0.0.1'
# o viceversa (especialmente en Windows).
DB_HOST=localhost

# Puerto de PostgreSQL (Por defecto es 5432)
DB_PORT=5432

# Nombre de la base de datos específica a la que te quieres conectar
DB_NAME=restaurante_db
